# Production Environment - Railway Deployment
VITE_API_URL=https://chatconnect-production.up.railway.app/api
VITE_WS_URL=wss://chatconnect-production.up.railway.app/ws

# Firebase Configuration for Push Notifications
# Get these values from your Firebase project console: https://console.firebase.google.com
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
# Generate VAPID Key in Firebase Console -> Project Settings -> Cloud Messaging -> Web Push Certificates
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here
